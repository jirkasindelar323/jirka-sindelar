---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  pageTitle?: string;
  description?: string;
  image?: string;
}

const {
  pageTitle = "Jirka Sindelar",
  description = "Software Engineer — builder, writer, learner.",
  image = "/og-image.png",
} = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <SEOHead title={pageTitle} description={description} image={image} />
    <title>{pageTitle}</title>
    <script is:inline>
      const theme = (() => {
        const stored = localStorage?.getItem("theme") ?? '';
        if (['dark', 'light'].includes(stored)) return stored;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      document.documentElement.classList.toggle('dark', theme === 'dark');
      localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-slate-100 font-sans">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Header />
      <main class="py-8">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>