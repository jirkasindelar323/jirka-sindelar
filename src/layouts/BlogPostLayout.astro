---
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags } = Astro.props;
---
<BaseLayout pageTitle={`${title} — Jiri Sindelar`} description={description}>
  <JsonLd type="blogPost" title={title} description={description} date={date} />
  <article class="prose prose-slate dark:prose-invert max-w-none">
    <header class="not-prose mb-8">
      <time class="text-sm text-slate-500 dark:text-slate-400" datetime={date.toISOString()}>
        {date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      <h1 class="mt-2 text-3xl font-bold">{title}</h1>
      {tags && tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="text-xs px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>
  
    <article class="prose dark:prose-invert max-w-none">
      <slot />
    </article>

  </article>
</BaseLayout>