---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return (a.data.order ?? 99) - (b.data.order ?? 99);
  })
  .slice(0, 3);
---
<BaseLayout>
  <Hero />

  {projects.length > 0 && (
    <section class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Projects</h2>
        <a href="/projects/" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">View all</a>
      </div>
      <div class="grid gap-4">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            sourceUrl={project.data.sourceUrl}
            liveUrl={project.data.liveUrl}
          />
        ))}
      </div>
    </section>
  )}

  {posts.length > 0 && (
    <section class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Recent Posts</h2>
        <a href="/blog/" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">View all</a>
      </div>
      <div class="grid gap-4">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>