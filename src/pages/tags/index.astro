---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tags = [...new Set(allPosts.flatMap((post) => post.data.tags ?? []))];
---
<BaseLayout pageTitle="Tags — Jiri Sindelar">
  <h1 class="text-3xl font-bold">Tags</h1>
  <div class="mt-8 flex flex-wrap gap-3">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag}/`}
        class="px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm hover:border-indigo-400 dark:hover:border-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400"
      >
        {tag}
      </a>
    ))}
  </div>
</BaseLayout>