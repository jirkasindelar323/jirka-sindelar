---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle="About — Jirka Sindelar" description="About Jirka Sindelar — software engineer, builder, learner.">
  <h1 class="text-3xl font-bold">About Me</h1>

  <section class="mt-8 space-y-4 text-slate-700 dark:text-slate-300">
    <p>
      I'm Jirka Sindelar, a software engineer based in Melbourne. I come from a Java backend
      background and I'm now exploring full-stack product development end to end — from
      idea to deployment.
    </p>
    <p>
      Outside of code, I enjoy volunteering, improv, and nature.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-semibold">What I'm open to</h2>
    <p class="mt-3 text-slate-600 dark:text-slate-400">
      Interesting engineering challenges, collaboration on side projects, and conversations
      about software, agentic design, and building products.
    </p>
  </section>
</BaseLayout>
