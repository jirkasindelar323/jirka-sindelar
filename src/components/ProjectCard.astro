---
interface Props {
  title: string;
  description: string;
  tags: string[];
  sourceUrl?: string;
  liveUrl?: string;
}

const { title, description, tags, sourceUrl, liveUrl } = Astro.props;
---
<article class="rounded-lg border border-slate-200 dark:border-slate-700 p-5">
  <h3 class="text-lg font-semibold">{title}</h3>
  <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{description}</p>
  <div class="mt-3 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs px-2 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300">
        {tag}
      </span>
    ))}
  </div>
  {(sourceUrl || liveUrl) && (
    <div class="mt-4 flex gap-4 text-sm">
      {sourceUrl && (
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="text-indigo-600 dark:text-indigo-400 hover:underline">
          Source
        </a>
      )}
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="text-indigo-600 dark:text-indigo-400 hover:underline">
          Live
        </a>
      )}
    </div>
  )}
</article>
