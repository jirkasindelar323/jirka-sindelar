---
const socialLinks = [
  { platform: "GitHub", href: "https://github.com/jirkasindelar323" },
  { platform: "LinkedIn", href: "https://www.linkedin.com/in/jiri-sindelar-540a5b143" },
  { platform: "X", href: "https://x.com/sindelar_jirka" },
  { platform: "Instagram", href: "https://www.instagram.com/jirkasindelar323/" },
];
---
<footer class="border-t border-slate-200 dark:border-slate-700 py-8 mt-12">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500 dark:text-slate-400">
    <p>&copy; {new Date().getFullYear()} Jirka Sindelar</p>
    <div class="flex gap-4">
      <a
        href="/jiri-sindelar-cv-short.pdf"
        class="hover:text-indigo-600 dark:hover:text-indigo-400"
      >
        CV
      </a>
      {socialLinks.map(({ platform, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-indigo-600 dark:hover:text-indigo-400"
        >
          {platform}
        </a>
      ))}
    </div>
  </div>
</footer>